rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function myUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myProfileExists() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function myRole() {
      return myProfileExists() ? myUserDoc().data.role : null;
    }

    function myOrgId() {
      return myProfileExists() ? myUserDoc().data.organizationId : null;
    }

    function mySiteIds() {
      return myProfileExists() ? myUserDoc().data.siteIds : [];
    }

    function isAdmin() {
      return myRole() == 'admin';
    }

    function isManager() {
      return myRole() == 'manager' || isAdmin();
    }

    function isSSA() {
      return myRole() == 'ssa';
    }

    function isCaseworker() {
      return myRole() == 'caseworker';
    }

    function sameOrg(orgId) {
      return myProfileExists() && orgId == myOrgId();
    }

    function sharesSite(siteId) {
      return siteId in mySiteIds();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (userId == request.auth.uid || isAdmin());
      allow create: if isAdmin()
        && request.resource.data.id == userId
        && request.resource.data.role in ['caseworker', 'ssa', 'manager', 'admin'];
      allow update: if isAdmin()
        && request.resource.data.id == userId
        && request.resource.data.role in ['caseworker', 'ssa', 'manager', 'admin'];
      allow delete: if false;
    }

    match /organizations/{organizationId} {
      allow read: if sameOrg(organizationId) && (isManager() || isSSA() || isCaseworker());
      allow create, update: if sameOrg(organizationId) && isAdmin();
      allow delete: if false;
    }

    match /sites/{siteId} {
      allow read: if sameOrg(resource.data.organizationId)
        && (isManager() || (isSSA() && sharesSite(siteId)) || (isCaseworker() && sharesSite(siteId)) || isAdmin());
      allow create, update: if sameOrg(request.resource.data.organizationId) && isAdmin();
      allow delete: if false;
    }

    match /clients/{clientId} {
      allow read: if sameOrg(resource.data.organizationId)
        && (
          isAdmin()
          || isManager()
          || (isSSA() && sharesSite(resource.data.siteId))
          || (isCaseworker() && request.auth.uid in resource.data.assignedWorkerIds)
        );
      allow create, update: if sameOrg(request.resource.data.organizationId)
        && (isAdmin() || isManager() || (isSSA() && sharesSite(request.resource.data.siteId)));
      allow delete: if sameOrg(resource.data.organizationId) && isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if sameOrg(resource.data.organizationId) && (isAdmin() || isManager());
      allow create: if sameOrg(request.resource.data.organizationId) && (isAdmin() || isManager() || isSSA());
      allow update, delete: if false;
    }

    match /{collectionName}/{docId} {
      allow read: if sameOrg(resource.data.organizationId)
        && (
          isAdmin()
          || isManager()
          || (isSSA() && sharesSite(resource.data.siteId))
          || (isCaseworker() && resource.data.siteId in mySiteIds())
        );
      allow create, update: if sameOrg(request.resource.data.organizationId)
        && (isAdmin() || isManager() || (isSSA() && request.resource.data.siteId in mySiteIds()));
      allow delete: if sameOrg(resource.data.organizationId) && isAdmin();
    }
  }
}
